---
interface Props {
  href: string;
  class?: string;
  target?: string;
  rel?: string;
}

const { href, class: className = "", target, rel: relProp, ...props } = Astro.props;
const rel = relProp ?? (target === "_blank" ? "noopener noreferrer" : undefined);
const baseClasses = "hover:text-rose-700 dark:hover:text-gray-300 border-b-2 border-solid border-rose-700 dark:border-gray-300 focus:outline-none focus:ring-2 focus:ring-rose-700 dark:focus:ring-gray-300 rounded-sm";
---

<a 
  href={href} 
  class={`${baseClasses} ${className}`}
  target={target}
  rel={rel}
  {...props}
>
  <slot />
</a>