---
import { type CollectionEntry, render } from "astro:content";
import { Image } from "astro:assets";
import ExternalLinkIcon from "../../assets/svgs/external-link.svg";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Pill from "../../components/Pill.astro";
import { getPublishedWork } from "../../utils/work";

interface Props {
	entry: CollectionEntry<"work">;
}

export async function getStaticPaths() {
	const work = await getPublishedWork();
	return work.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} noindex={true}>
	<main class="flex-1 md:my-24 my-12 mx-6">
		<div class="flex flex-col items-center">
			<h1
				class="text-xl md:text-4xl my-4 md:my-9 text-center font-black dark:text-white"
			>
				{entry.data.title}
			</h1>
			<Image
				class="my-5 border border-gray-700 dark:border-gray-500"
				src={entry.data.img}
				alt={entry.data.img_alt}
			/>

			<div
				class="[&_h3]:text-2xl [&_ul]:list-disc [&_ul]:list-inside max-w-251.5"
			>
				<div class="*:text-xl *:py-2">
					<Content />
				</div>

				<h2 class="font-medium text-xl mt-5">Project Involvement:</h2>
				<div class="flex flex-wrap gap-4 my-5">
					{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
				</div>
				{
					entry.data.external_site_link && (
						<a
							class="btn-gradient flex justify-center bg-gray-600 dark:bg-gray-500 uppercase max-w-40 rounded-lg text-white text-xl my-8 py-4 px-6"
							rel="noopener noreferrer"
							href={entry.data.external_site_link}
							target="_blank"
						>
							<span class="mr-1">Visit Site</span>

							<ExternalLinkIcon
								width="14px"
								height="14px"
								class="fill-current mt-0.75"
							/>
						</a>
					)
				}
				{
					entry.data.work_with_company_url && (
						<p>
							Work done with
							<a
								class="border-b-2 border-dashed border-rose-700 hover:bg-rose-200 dark:border-gray-300 dark:hover:bg-gray-500"
								rel="noopener noreferrer"
								href={entry.data.work_with_company_url}
								target="_blank"
							>
								{entry.data.work_with_company_name}
							</a>
						</p>
					)
				}
			</div>
		</div>
	</main>
</BaseLayout>
