---
import BaseLayout from "../layouts/BaseLayout.astro";
import Link from "../components/Link.astro";
import { Image } from "astro:assets";
import mattSteeleIllustrated from "../assets/images/mattsteele-illustrated.png";
import mattSteeleSignature from "../assets/images/mattsteele-signature.png";
---

<BaseLayout title="About | Matt Steele" description="Matt Steele is a Senior Software Engineer in Denver, Colorado specializing in Developer Experience, design systems, and scalable web applications.">
	<main class="flex flex-1 flex-col md:my-24 my-20">
		<div class="mx-6 flex flex-col items-center">
			<div
				class="relative w-full md:w-96 h-96 bg-gray-900 dark:bg-gray-700 p-6"
			>
				<h1 class="text-white text-2xl uppercase mb-1 tracking-wide">
					Matt Steele
				</h1>
				<p class="text-white text-base">Software Engineer</p>
				<Image
					class="absolute bottom-0 right-0"
					src={mattSteeleIllustrated}
					alt="Illustration of Matt Steele"
					width="326"
					height="326"
				/>
			</div>

			<div class="mt-12 text-xl space-y-4 dark:text-white max-w-251.5">
				<p>
					I specialize in improving Developer Experience (DX) by building and
					optimizing tools, frameworks, and processes for productivity and
					growth — including leveraging AI and LLMs to accelerate workflows and
					reduce friction for engineering teams.
				</p>

				<p>
					My work includes design systems, modular components, rapid
					prototyping, and implementing scalable proof-of-concept projects,
					often integrating AI-powered tooling to improve developer productivity.
				</p>

				<p>I work as a Senior Software Engineer in Denver, Colorado.</p>

				<p>
					You can <Link href="/resume/">view my resume</Link>.</p>

				<div class="mt-10">
					<Image
						class="mb-4 dark:invert"
						src={mattSteeleSignature}
						alt="Matt Steele's Signature"
						width="100"
						height="33"
					/>
					<p class="text-lg uppercase mt-1 tracking-wide">Matt Steele</p>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>
