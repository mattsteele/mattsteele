---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Link from "@/components/Link.astro";
import { Image } from "astro:assets";
import mattSteeleIllustrated from "@/assets/images/mattsteele-illustrated.png";
import mattSteeleSignature from "@/assets/images/mattsteele-signature.png";
---

<BaseLayout
	title="About | Matt Steele"
	description="Matt Steele is a Senior Software Engineer in Denver, Colorado specializing in Developer Experience, design systems, and scalable web applications."
>
	<main class="my-20 flex flex-1 flex-col md:my-24">
		<div class="mx-6 flex flex-col items-center">
			<div
				class="relative h-96 w-full bg-gray-900 p-6 md:w-96 dark:bg-gray-700"
			>
				<h1 class="mb-1 text-2xl tracking-wide text-white uppercase">
					Matt Steele
				</h1>
				<p class="text-base text-white">Software Engineer</p>
				<Image
					class="absolute right-0 bottom-0"
					src={mattSteeleIllustrated}
					alt="Illustration of Matt Steele"
					width={326}
					height={326}
					densities={[1, 2]}
					format="webp"
					quality={85}
					loading="eager"
					fetchpriority="high"
				/>
			</div>

			<div class="mt-12 max-w-251.5 space-y-4 text-xl dark:text-white">
				<p>
					I specialize in improving Developer Experience (DX) by building and
					optimizing tools, frameworks, and processes for productivity and
					growth — including leveraging AI and LLMs to accelerate workflows and
					reduce friction for engineering teams.
				</p>

				<p>
					My work includes design systems, modular components, rapid
					prototyping, and implementing scalable proof-of-concept projects,
					often integrating AI-powered tooling to improve developer
					productivity.
				</p>

				<p>I work as a Senior Software Engineer in Denver, Colorado.</p>

				<p>
					You can <Link href="/resume/">view my resume</Link>.
				</p>

				<div class="mt-10">
					<Image
						class="mb-4 dark:invert"
						src={mattSteeleSignature}
						alt="Matt Steele's Signature"
						width={100}
						height={33}
						densities={[1, 2]}
						format="webp"
						quality={85}
					/>
					<p class="mt-1 text-lg tracking-wide uppercase">Matt Steele</p>
				</div>
			</div>
		</div>
	</main>
</BaseLayout>
