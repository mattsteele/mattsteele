---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmailIcon from "@/assets/svgs/email.svg";
import LaptopIcon from "@/assets/svgs/laptop.svg";
import PrintIcon from "@/assets/svgs/print.svg";
---

<BaseLayout
	title="Resume | Matt Steele"
	description="Matt Steele's Resume"
	noindex={true}
>
	<div class="flex dark:text-white">
		<!-- Sidebar -->
		<aside
			class="hidden w-1/5 bg-gray-500 p-6 md:block dark:bg-gray-700 print:hidden"
		>
			<div class="flex justify-end pt-4 pr-6">
				<button
					id="print-resume"
					class="cursor-pointer text-white hover:text-rose-200 dark:hover:text-gray-300"
					aria-label="Print Resume"
				>
					<PrintIcon width="28px" height="28px" aria-hidden="true" />
				</button>
			</div>
			<script is:inline>
				document
					.getElementById("print-resume")
					?.addEventListener("click", () => window.print());
			</script>
		</aside>

		<!-- Main Content -->
		<div class="mt-6 flex-1 md:mt-12">
			<header class="mx-6 md:mx-20">
				<div class="mb-6 flex items-center">
					<div>
						<h1 class="text-5xl font-bold print:text-black">Matt Steele</h1>
						<p class="mt-2 text-xl">
							<span>Senior Software Engineer</span>
							<span class="mx-2" aria-hidden="true"> | </span>
							<span>Denver, CO</span>
						</p>
						<div
							class="flex flex-wrap items-center gap-x-6 gap-y-2 pt-4 print:pt-0"
						>
							<a
								href="mailto:mattsteele@outlook.com"
								class="flex items-center hover:underline"
							>
								<EmailIcon width="20px" height="20px" aria-hidden="true" />
								<span class="ml-2 print:ml-0">mattsteele@outlook.com</span>
							</a>
							<a
								href="https://mattsteele.dev"
								class="flex items-center hover:underline"
							>
								<LaptopIcon width="20px" height="20px" aria-hidden="true" />
								<span class="ml-2 print:ml-0">mattsteele.dev</span>
							</a>
						</div>
					</div>
				</div>
			</header>

			<main class="mx-6 md:mx-20">
				<section class="mb-12 max-w-251.5 space-y-2">
					<h2 class="mb-6 text-3xl font-bold">Professional Summary</h2>
					<hr class="mb-4 border-gray-300 dark:border-gray-600" />
					<p class="mb-4 text-lg leading-relaxed">
						I am a Software Engineer specializing in design systems, developer
						tools, and scalable web applications with Amazon Web Services (AWS).
						I optimize developer experience (DX) through modern frameworks,
						automation, and AI-powered tooling.
					</p>
					<p class="text-lg leading-relaxed">
						I deliver accessible, high-performance JavaScript solutions using
						Angular, React, and Vue with expertise in documentation,
						collaboration, and best practices for modern web development,
						including integrating LLMs to accelerate engineering workflows.
					</p>
				</section>

				<section class="mb-12 max-w-251.5 space-y-2">
					<h2 class="mb-6 text-3xl font-bold">Work Experience</h2>
					<hr class="mb-4 border-gray-300 dark:border-gray-600" />

					<article class="mb-10">
						<div class="mb-4">
							<p class="mb-1 tracking-wider text-gray-500 dark:text-white">
								<time class="text-sm" datetime="2020-10-01">10/2020</time>
								<span class="mx-1 text-sm uppercase" aria-hidden="true">
									-
								</span>
								<span class="text-sm uppercase">Present</span>
							</p>
							<h3 class="pb-1 text-2xl font-semibold">
								Senior Software Engineer - Design Systems
							</h3>
							<p class="text-sm dark:text-white">
								<a
									href="https://www.spectrum.net"
									target="_blank"
									rel="noopener noreferrer"
									class="text-gray-800 hover:underline dark:text-white"
									>Charter Communications</a
								>
								<span class="mx-1" aria-hidden="true"> | </span>
								<span>Denver, CO</span>
							</p>
						</div>
						<ul class="ml-6 list-disc space-y-2 text-lg leading-relaxed">
							<li>
								Manage and scale a company-wide design system to ensure
								consistent, accessible user interfaces across multiple products.
							</li>
							<li>
								Develop and maintain reusable component libraries using Angular
								and React, improving developer efficiency and code quality.
							</li>
							<li>
								Create comprehensive documentation and onboarding materials to
								support engineering teams and drive adoption of best practices.
							</li>
							<li>
								Collaborate with product, design, and engineering teams to
								deliver solutions aligned with business goals and accessibility
								standards.
							</li>
							<li>
								Implement tools, automation, and AI-powered solutions using LLMs
								to streamline workflows and enhance developer experience (DX).
							</li>
						</ul>
					</article>

					<article class="mb-10">
						<div class="mb-4">
							<p class="mb-1 tracking-wider text-gray-500 dark:text-white">
								<time class="text-sm" datetime="2017-10-01">10/2017</time>
								<span class="mx-1 text-sm uppercase" aria-hidden="true">
									-
								</span>
								<time class="text-sm" datetime="2020-10-01">10/2020</time>
							</p>
							<h3 class="pb-1 text-2xl font-semibold">
								Senior Software Engineer - Prototyping
							</h3>
							<p class="text-sm dark:text-white">
								<a
									href="https://www.spectrum.net"
									target="_blank"
									rel="noopener noreferrer"
									class="text-gray-800 hover:underline dark:text-white"
									>Charter Communications</a
								>
								<span class="mx-1" aria-hidden="true"> | </span>
								<span>Denver, CO</span>
							</p>
						</div>
						<ul class="ml-6 list-disc space-y-2 text-lg leading-relaxed">
							<li>
								Designed and implemented prototypes and proof-of-concept (POC)
								projects using Vue and Angular to validate new product ideas.
							</li>
							<li>
								Worked with cross-functional teams to gather requirements,
								conduct research, and deliver functional prototypes.
							</li>
							<li>
								Focused on user experience (UX) and accessibility, ensuring
								solutions met performance and usability standards.
							</li>
							<li>
								Optimized applications for speed and scalability across multiple
								devices and platforms.
							</li>
						</ul>
					</article>

					<article class="mb-10">
						<div class="mb-4">
							<p class="mb-1 tracking-wider text-gray-500 dark:text-white">
								<time class="text-sm" datetime="2016-05-01">05/2016</time>
								<span class="mx-1 text-sm" aria-hidden="true"> - </span>
								<time class="text-sm" datetime="2017-10-01">10/2017</time>
							</p>
							<h3 class="pb-1 text-2xl font-semibold">Senior Web Developer</h3>
							<p class="text-sm dark:text-white">
								<a
									href="https://clover.partners/"
									target="_blank"
									rel="noopener noreferrer"
									class="text-gray-800 hover:underline dark:text-white"
									>Clover Partners</a
								>
								<span class="mx-1" aria-hidden="true"> | </span>
								<span>Denver, CO</span>
							</p>
						</div>
						<ul class="ml-6 list-disc space-y-2 text-lg leading-relaxed">
							<li>
								Developed custom client-facing web applications using JavaScript
								and PHP, integrated with Craft and Statamic CMS platforms.
							</li>
							<li>
								Translated client requirements and designs into functional,
								user-centric solutions.
							</li>
							<li>
								Delivered tailored eCommerce platforms, optimizing payment
								systems and improving user experience to increase engagement and
								conversions.
							</li>
							<li>
								Collaborated with clients and internal teams to ensure project
								success and satisfaction.
							</li>
						</ul>
					</article>
				</section>

				<section class="mb-10 max-w-251.5 space-y-2">
					<h2 class="mb-6 text-3xl font-bold">Education</h2>
					<hr class="mb-4 border-gray-300 dark:border-gray-600" />
					<article>
						<div>
							<h3 class="pb-1 text-2xl font-semibold">Bachelor of Fine Arts</h3>
							<p class="text-sm dark:text-white">
								<a
									href="https://www.academyart.edu/"
									target="_blank"
									rel="noopener noreferrer"
									class="text-gray-800 hover:underline dark:text-white"
									>Academy of Art University</a
								>
								<span class="mx-1" aria-hidden="true"> | </span>
								<span>San Francisco, CA</span>
							</p>
						</div>
					</article>
				</section>

				<section class="mb-10 max-w-251.5 space-y-2">
					<h2 class="mb-6 text-3xl font-bold">Skills</h2>
					<hr class="mb-4 border-gray-300 dark:border-gray-600" />
					<ul class="ml-6 list-disc space-y-2 text-lg leading-relaxed">
						<li>Design Systems</li>
						<li>Developer Experience (DX)</li>
						<li>Amazon Web Services (AWS)</li>
						<li>JavaScript, TypeScript</li>
						<li>Angular, React, Vue</li>
						<li>Accessibility</li>
						<li>Component Libraries</li>
						<li>Documentation</li>
						<li>Cross-functional Collaboration</li>
						<li>Performance Optimization</li>
						<li>eCommerce Platforms</li>
						<li>Content Management Systems (CMS's)</li>
					</ul>
				</section>
			</main>
			<footer class="bg-gray-600 p-10 dark:bg-gray-800">
				<p class="text-white">
					Last updated: {
						new Date().toLocaleDateString(undefined, {
							month: "numeric",
							year: "numeric",
						})
					}
				</p>
			</footer>
		</div>
	</div>
</BaseLayout>
